

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NewsSite</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-light">
            <div class="container-fluid">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">عين على الخبر</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">الرئيسية</a>
                        </li>
                        <li class="nav-item">
                            <!-- Use Home index for public news listing so URL does not show /News -->
                            <a class="nav-link" asp-controller="Home" asp-action="Index">الأخبار</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.RouteUrl("videos")">الفيديوهات</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.RouteUrl("images")">الصور</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.RouteUrl("documents")">المستندات</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="News" asp-action="Create">إنشاء خبر</a>
                        </li>
                        @if (User.IsInRole("Admin") || User.IsInRole("Owner"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Users" asp-action="Index">إدارة المستخدمين</a>
                            </li>
                        }
                    </ul>
                    <form asp-controller="News" asp-action="Search" method="get" class="d-flex">
                        <input class="form-control me-2" type="text" name="query" placeholder="ابحث عن خبر..." aria-label="Search" />
                        <button class="btn btn-outline-success" type="submit">بحث</button>
                    </form>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <footer class="border-top footer text-muted">
        <div class="container text-center py-2">
            <small class="text-muted">&copy; @DateTime.Now.Year</small>
        </div>
    </footer>

    <!-- Fixed bottom site name bar -->
    <div class="site-name-bar bg-dark text-white text-center py-2">
        عين على الخبر
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>

