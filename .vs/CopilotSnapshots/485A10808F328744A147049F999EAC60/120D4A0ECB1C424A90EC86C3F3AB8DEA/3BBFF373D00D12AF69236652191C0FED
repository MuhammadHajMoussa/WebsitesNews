@page
@model IndexModel
@{
    ViewData["Title"] = "الملف الشخصي";
}

<div class="container py-4">
    <div class="card shadow-sm">
        <div class="card-body">
            <div class="d-flex align-items-center mb-3">
                <div>
                    <img id="avatarPreviewTop" src="@Model.AvatarUrl" class="rounded-circle border" style="width:72px;height:72px;object-fit:cover;" alt="avatar" />
                </div>
                <div class="flex-grow-1 me-3">
                    <h5 class="mb-0">@Model.FullName</h5>
                    <small class="text-muted">@Model.Email</small>
                </div>
                <div>
                    <a class="btn btn-outline-secondary" asp-page="/Index">رجوع</a>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.StatusMessage))
            {
                <div class="alert alert-success">@Model.StatusMessage</div>
            }

            <div class="row">
                <div class="col-lg-4 mb-4">
                    <div class="card border-0 bg-light p-3">
                        <div class="text-center">
                            <img id="avatarPreview" src="@Model.AvatarUrl" class="rounded-circle mb-3" style="width:140px;height:140px;object-fit:cover;" alt="avatar" />
                            <h6 class="mb-0">@Model.FullName</h6>
                            <p class="text-muted small">@Model.Email</p>
                        </div>
                        <hr />
                        <div class="mb-2">
                            <strong>الأدوار</strong>
                            <div class="mt-2">
                                @if (Model.Roles != null && Model.Roles.Length > 0)
                                {
                                    foreach (var r in Model.Roles)
                                    {
                                        <span class="badge bg-secondary me-1">@r</span>
                                    }
                                }
                                else
                                {
                                    <div class="text-muted small">لا توجد أدوار</div>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-8">
                    <form method="post" enctype="multipart/form-data">
                        <input type="hidden" asp-for="Id" />
                        <div class="card mb-3">
                            <div class="card-body">
                                <h6 class="card-title">البيانات الشخصية</h6>
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label asp-for="UserName" class="form-label">اسم المستخدم</label>
                                        <input asp-for="UserName" class="form-control form-control-lg" />
                                        <span asp-validation-for="UserName" class="text-danger"></span>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label asp-for="FullName" class="form-label">الاسم الكامل</label>
                                        <input asp-for="FullName" class="form-control form-control-lg" />
                                        <span asp-validation-for="FullName" class="text-danger"></span>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label asp-for="Email" class="form-label">البريد الإلكتروني</label>
                                        <input asp-for="Email" class="form-control" />
                                        <span asp-validation-for="Email" class="text-danger"></span>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label asp-for="PhoneNumber" class="form-label">الهاتف</label>
                                        <input asp-for="PhoneNumber" class="form-control" />
                                        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="card mb-3">
                            <div class="card-body">
                                <h6 class="card-title">الأمان</h6>
                                <div class="mb-3">
                                    <label asp-for="CurrentPassword" class="form-label">كلمة المرور الحالية</label>
                                    <input asp-for="CurrentPassword" class="form-control" />
                                    <span asp-validation-for="CurrentPassword" class="text-danger"></span>
                                </div>
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label asp-for="NewPassword" class="form-label">كلمة المرور الجديدة</label>
                                        <input asp-for="NewPassword" class="form-control" />
                                        <span asp-validation-for="NewPassword" class="text-danger"></span>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label asp-for="ConfirmPassword" class="form-label">تأكيد كلمة المرور</label>
                                        <input asp-for="ConfirmPassword" class="form-control" />
                                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                                    </div>
                                </div>

                                <div class="form-check form-switch mb-2">
                                    <input asp-for="TwoFactorEnabled" class="form-check-input" />
                                    <label asp-for="TwoFactorEnabled" class="form-check-label">تفعيل التحقق الثنائي</label>
                                </div>
                                <div class="form-check form-switch mb-2">
                                    <input asp-for="EmailConfirmed" class="form-check-input" />
                                    <label asp-for="EmailConfirmed" class="form-check-label">تأكيد البريد الإلكتروني</label>
                                </div>
                            </div>
                        </div>

                        <div class="card mb-3">
                            <div class="card-body">
                                <h6 class="card-title">الصورة الشخصية</h6>
                                <div class="mb-3">
                                    <label asp-for="AvatarImage" class="form-label">رفع صورة</label>
                                    <input asp-for="AvatarImage" id="avatarInput" type="file" accept="image/*" class="form-control" />
                                    <small class="text-muted">مسموح: jpg, png, gif. الحجم الموصى به 300x300.</small>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end">
                            <button type="submit" class="btn btn-primary btn-lg">حفظ التغييرات</button>
                            <a asp-page="/Index" class="btn btn-outline-secondary btn-lg ms-3">إلغاء</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // avatar preview
        (function(){
            var input = document.getElementById('avatarInput');
            var preview = document.getElementById('avatarPreview');
            var previewTop = document.getElementById('avatarPreviewTop');
            if(!input) return;
            input.addEventListener('change', function(e){
                var file = input.files && input.files[0];
                if(!file) return;
                var reader = new FileReader();
                reader.onload = function(evt){
                    if(preview) preview.src = evt.target.result;
                    if(previewTop) previewTop.src = evt.target.result;
                };
                reader.readAsDataURL(file);
            });
        })();
    </script>
}
