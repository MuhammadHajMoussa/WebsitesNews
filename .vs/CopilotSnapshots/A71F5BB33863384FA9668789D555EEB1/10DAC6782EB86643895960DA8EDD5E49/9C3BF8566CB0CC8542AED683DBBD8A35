@model NewsSite.Models.News

@{
    ViewData["Title"] = Model.Title;
}

<h1>@Model.Title</h1>
<p>@Model.Content</p>
<p>التصنيف: @Model.Category.Name</p>
<p>الكاتب: @Model.Author.FullName</p>
<p>التاريخ: @Model.PublishDate.ToShortDateString()</p>
<p>المشاهدات: @Model.Views</p>
<p>الإعجابات: @Model.Likes</p>

<form asp-action="Like" asp-route-id="@Model.Id" method="post">
    <button type="submit" class="btn btn-primary">إعجاب</button>
</form>

<h2>التعليقات</h2>
@foreach (var comment in Model.Comments)
{
    <p>@comment.Content - بواسطة @comment.User.FullName - @comment.PostedDate.ToShortDateString()</p>
}

<h3>إضافة تعليق</h3>
<form asp-action="AddComment" asp-route-newsId="@Model.Id" method="post">
    <div class="form-group">
        <textarea name="content" rows="4" class="form-control"></textarea>
    </div>
    <button type="submit" class="btn btn-primary">إرسال</button>
</form>