@model IEnumerable<NewsSite.Models.News>

@{
    ViewData["Title"] = "الرئيسية";
}

@{
    // legacy category route protection removed — categories handled elsewhere
}

<div class="row mt-3">
    <div class="col-12 mb-3">
        <!-- Combined category dropdown (left, 1/3) and search bar (right, 2/3) -->
        <form id="searchForm" asp-controller="News" asp-action="Search" method="get" class="row g-0 align-items-center">
            <div class="col-md-4">
                <select id="categorySelect" name="category" class="form-select form-select-lg" aria-label="اختر قسم">
                    <option value="">كل الأقسام</option>
                    @if (ViewBag.Categories != null)
                    {
                        foreach (var c in ViewBag.Categories)
                        {
                            var optionHtml = $"<option value=\"{c.Name}\"{(ViewBag.SelectedCategory == c.Name ? " selected" : string.Empty)}>{c.Name}</option>";
                            @Html.Raw(optionHtml)
                        }
                    }
                    else
                    {
                        <option value="رياضة">رياضة</option>
                        <option value="تكنولوجيا">تكنولوجيا</option>
                        <option value="سياسة">سياسة</option>
                        <option value="ترفيه">ترفيه</option>
                    }
                </select>
            </div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var sel = document.getElementById('categorySelect');
            var form = document.getElementById('searchForm');
            if (!sel || !form) return;
            sel.addEventListener('change', function () {
                form.submit();
            });
        });
    </script>
}
            <div class="col-md-8">
                <div class="d-flex">
                    <input type="text" name="query" class="form-control form-control-lg" placeholder="ابحث عن خبر..." value='@(ViewContext.HttpContext.Request.Query["query"].ToString())' />
                    <button class="btn btn-primary btn-lg ms-2" type="submit">بحث</button>
                </div>
            </div>
        </form>
    </div>

    <div class="col-lg-12">
        <!-- Featured Carousel -->
        <div id="featuredCarousel" class="carousel slide mb-4" data-bs-ride="carousel">
            <div class="carousel-inner">
                @if (Model != null && Model.Any())
                {
                    var first = true;
                    foreach (var item in Model.Take(5))
                    {
                        <div class="carousel-item @(first ? "active" : "")">
                            <div class="card bg-dark text-white">
                            <img src="@(item.Images != null && item.Images.Any() ? Url.Action("GetFile","NewsFiles", new { id = item.Images.First().Id, type = "image" }) : Url.Content("~/images/placeholder-hero.jpg"))" class="d-block w-100" alt="@item.Title" />
                                <div class="card-img-overlay d-flex flex-column justify-content-end">
                                    <h3 class="card-title">@item.Title</h3>
                                    <p class="card-text">@item.PublishDate.ToShortDateString() - @item.Author.FullName</p>
                                    <a asp-controller="News" asp-action="Details" asp-route-id="@item.Id" class="btn btn-primary">اقرأ المزيد</a>
                                </div>
                            </div>
                        </div>
                        first = false;
                    }
                }
            </div>
            <button class="carousel-control-prev" type="button" data-bs-target="#featuredCarousel" data-bs-slide="prev">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Previous</span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#featuredCarousel" data-bs-slide="next">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Next</span>
            </button>
        </div>

        <!-- News list -->
        <div class="row">
            @if (Model != null)
            {
                foreach (var item in Model)
                {
                    <div class="col-md-6 mb-4">
                        <div class="card h-100">
                            <img src="@(item.Images != null && item.Images.Any() ? Url.Action("GetFile","NewsFiles", new { id = item.Images.First().Id, type = "image" }) : Url.Content("~/images/placeholder-thumb.jpg"))" class="card-img-top" alt="@item.Title">
                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title">@item.Title</h5>
                                <p class="card-text text-muted">@item.PublishDate.ToShortDateString() • @item.Category.Name</p>
                                <p class="card-text">@item.Content?.Substring(0, Math.Min(item.Content.Length, 120))...</p>
                                <a asp-controller="News" asp-action="Details" asp-route-id="@item.Id" class="mt-auto btn btn-outline-primary">اقرأ المزيد</a>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>


</div>
