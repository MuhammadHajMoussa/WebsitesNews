                                !contentType.Equals("text/plain"))
                            {
                                ModelState.AddModelError($"Files[{i}]", "تنسيق المستند غير مدعوم. التنسيقات المدعومة هي: PDF، Text.");
                                ViewBag.Categories = _context.Categories.ToList();
                                return View(model);
                            }
                        }
                        else
                        {
                            ModelState.AddModelError($"FileTypes[{i}]", "نوع الملف غير صالح.");
                            ViewBag.Categories = _context.Categories.ToList();
                            return View(model);
                        }

                        switch (fileType.ToLower())
                        {
                            case "video":
                                var video = new Video
                                {
                                    NewsId = model.Id,
                                    Title = fileTitle,
                                    FileName = Path.GetFileName(file.FileName),
                                    FileContent = fileContent,
                                    FileType = contentType,
                                    FileSize = file.Length,
