                                };
                                _context.Videos.Add(video);
                                break;
                            case "image":
                                var image = new Image
                                {
                                    NewsId = model.Id,
                                    Title = fileTitle,
                                    FileName = Path.GetFileName(file.FileName),
                                    FileContent = fileContent,
                                    FileType = contentType,
                                    FileSize = file.Length,
                                    UploadDate = DateTime.Now
                                };
